{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "replymaven",
  "main": "worker/index.ts",
  "compatibility_date": "2025-05-24",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "35bc7a4522237728214ba9d54c36002e",
  "assets": {
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/help/*", "/.well-known/*"],
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "invocation_logs": false,
    },
  },
  "placement": {
    "mode": "smart",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "supportbot-db",
      "database_id": "930df889-1d05-4762-8fcf-072f9521fd20",
      "migrations_dir": "worker/db/drizzle",
      "remote": true,
    },
  ],
  "r2_buckets": [
    {
      "binding": "UPLOADS",
      "bucket_name": "supportbot-uploads",
      "remote": true,
    },
    {
      "binding": "WIDGET_BUCKET",
      "bucket_name": "replymaven-widget",
      "remote": true,
    },
  ],
  "kv_namespaces": [
    {
      "binding": "CONVERSATIONS_CACHE",
      "id": "5ba5fdd76ae84641aadfa57863e3c45b",
      "remote": true,
    },
  ],
  "ai": {
    "binding": "AI",
    "remote": true,
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "CONVERSATION_DO",
        "class_name": "ConversationDO",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1-conversation-do",
      "new_sqlite_classes": ["ConversationDO"],
    },
  ],
  "queues": {
    "consumers": [
      {
        "queue": "replymaven-crawl",
        // Deliver promptly — a long batching window adds dead time per crawl hop
        "max_batch_timeout": 5,
        "max_batch_size": 5,
        // The consumer acks-and-fails pages itself at MAX_CRAWL_ATTEMPTS (3);
        // this is a safety net so messages are never silently dropped earlier
        "max_retries": 5,
        // Keep Browser Rendering API pressure low to avoid 429 storms
        "max_concurrency": 2,
      },
    ],
    "producers": [
      {
        "queue": "replymaven-crawl",
        "binding": "CRAWL_QUEUE",
      },
    ],
  },
  "vars": {
    "BETTER_AUTH_URL": "https://replymaven.com",
    "CF_ACCOUNT_ID": "35bc7a4522237728214ba9d54c36002e",
    "AI_MODEL": "gpt-5-chat-latest",
    "STRIPE_STARTER_MONTHLY_PRICE_ID": "price_1T6BKmR3FrLxl9TOBoGEMvvA",
    "STRIPE_STARTER_ANNUAL_PRICE_ID": "price_1T6E7yR3FrLxl9TOvPWqvcPV",
    "STRIPE_STANDARD_MONTHLY_PRICE_ID": "price_1T6BNHR3FrLxl9TOPqOKQytI",
    "STRIPE_STANDARD_ANNUAL_PRICE_ID": "price_1T6E6LR3FrLxl9TOBPG8TVgQ",
    "STRIPE_BUSINESS_MONTHLY_PRICE_ID": "price_1T6BNeR3FrLxl9TO8vW1L13I",
    "STRIPE_BUSINESS_ANNUAL_PRICE_ID": "price_1T6E5SR3FrLxl9TOvsR2mULp",
  },
}
