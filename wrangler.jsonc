{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "replymaven",
  "main": "worker/index.ts",
  "compatibility_date": "2025-05-24",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "35bc7a4522237728214ba9d54c36002e",
  "assets": {
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
  },
  "observability": {
    "enabled": true,
  },
  "placement": {
    "mode": "smart",
    "hint": "aws:us-east-1",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "supportbot-db",
      "database_id": "930df889-1d05-4762-8fcf-072f9521fd20",
      "migrations_dir": "worker/db/drizzle",
      "remote": true,
    },
  ],
  "r2_buckets": [
    {
      "binding": "UPLOADS",
      "bucket_name": "supportbot-uploads",
      "remote": true,
    },
  ],
  "kv_namespaces": [
    {
      "binding": "CONVERSATIONS_CACHE",
      "id": "5ba5fdd76ae84641aadfa57863e3c45b",
      "remote": true,
    },
  ],
  "ai": {
    "binding": "AI",
    "remote": true,
  },
  "queues": {
    "consumers": [
      {
        "queue": "replymaven-crawl",
        "max_batch_timeout": 30,
        "max_batch_size": 5,
      },
    ],
    "producers": [
      {
        "queue": "replymaven-crawl",
        "binding": "CRAWL_QUEUE",
      },
    ],
  },
  "vars": {
    "BETTER_AUTH_URL": "https://replymaven.com",
    "CF_ACCOUNT_ID": "35bc7a4522237728214ba9d54c36002e",
    "AI_MODEL": "gpt-5-chat-latest",
    "STRIPE_ESSENTIAL_MONTHLY_PRICE_ID": "price_essential_monthly",
    "STRIPE_ESSENTIAL_ANNUAL_PRICE_ID": "price_essential_annual",
    "STRIPE_PRO_MONTHLY_PRICE_ID": "price_pro_monthly",
    "STRIPE_PRO_ANNUAL_PRICE_ID": "price_pro_annual",
    "STRIPE_BUSINESS_MONTHLY_PRICE_ID": "price_business_monthly",
    "STRIPE_BUSINESS_ANNUAL_PRICE_ID": "price_business_annual",
  },
  "env": {
    "production": {
      "vars": {
        "BETTER_AUTH_URL": "https://replymaven.com",
        "CF_ACCOUNT_ID": "35bc7a4522237728214ba9d54c36002e",
        "AI_MODEL": "gpt-5-chat-latest",
        "STRIPE_ESSENTIAL_MONTHLY_PRICE_ID": "price_essential_monthly",
        "STRIPE_ESSENTIAL_ANNUAL_PRICE_ID": "price_essential_annual",
        "STRIPE_PRO_MONTHLY_PRICE_ID": "price_pro_monthly",
        "STRIPE_PRO_ANNUAL_PRICE_ID": "price_pro_annual",
        "STRIPE_BUSINESS_MONTHLY_PRICE_ID": "price_business_monthly",
        "STRIPE_BUSINESS_ANNUAL_PRICE_ID": "price_business_annual",
      },
    },
  },
}
